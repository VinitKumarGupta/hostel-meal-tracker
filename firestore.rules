rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Helper function to check if the current user is an admin
      function isAdmin() {
        return request.auth != null && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
      }

      // Roommates can view all roommate profiles and meal counts
      allow read: if request.auth != null;
      
      // A roommate can create their own profile document
      allow create: if request.auth != null && request.auth.uid == userId;

      // A roommate can update their own profile document
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // An admin can update any user document
      allow update: if isAdmin();
      
      // Deletions are not allowed for roommate records to prevent data loss
      allow delete: if false;

      // Logs subcollection rules
      match /logs/{logId} {
        // Owner can read their logs
        allow read: if request.auth != null && request.auth.uid == userId;
        
        // Owner can write to their logs
        allow write: if request.auth != null && request.auth.uid == userId;
        
        // Admin can write to any user's logs (needed for global resets)
        allow write: if isAdmin();
      }
    }
  }
}
