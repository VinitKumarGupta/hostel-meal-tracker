rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the current user is an admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    // Notice Board rules
    match /notices/{noticeId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      // Roommates can view all roommate profiles and meal counts
      allow read: if request.auth != null;
      
      // A roommate can create their own profile document (isAdmin must be false or omitted)
      allow create: if request.auth != null && 
                       request.auth.uid == userId && 
                       request.resource.data.get('isAdmin', false) == false;

      // A roommate can update their own profile document (cannot change their own isAdmin role)
      allow update: if request.auth != null && 
                       request.auth.uid == userId && 
                       request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false);
      
      // An admin can update any user document
      allow update: if isAdmin();
      
      // Deletions are not allowed for roommate records to prevent data loss
      allow delete: if false;

      // Logs subcollection rules
      match /logs/{logId} {
        // Owner can read their logs
        allow read: if request.auth != null && request.auth.uid == userId;
        
        // Admin can read any user's logs (needed to fetch logs before deletion)
        allow read: if isAdmin();
        
        // Owner can write to their logs
        allow write: if request.auth != null && request.auth.uid == userId;
        
        // Admin can write to any user's logs (needed for global resets)
        allow write: if isAdmin();
      }
    }
  }
}
