rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Helper function to check if the current user is an admin
      function isAdmin() {
        return request.auth != null && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
      }

      // Roommates can view all roommate profiles and meal counts
      allow read: if request.auth != null;
      
      // A roommate can create their own profile document
      allow create: if request.auth != null && request.auth.uid == userId;

      // A roommate can update their own profile, or an admin can update any profile
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Deletions are not allowed for roommate records to prevent data loss
      allow delete: if false;

      // Logs subcollection rules
      match /logs/{logId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }
  }
}
